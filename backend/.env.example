NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173,http://localhost:5174,https://ai-travel-planner-frontend-771jir6j7.vercel.app

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-travel-planner

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Gemini and LangChain
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-3.1-flash-lite,gemini-3-flash-preview
ALLOW_AI_FALLBACK=false

# n8n automation
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/travel-planner

# Google Sheets logging
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_RANGE=Logs!A:H
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# SMTP / Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM="AI Travel Planner <your-email@example.com>"
